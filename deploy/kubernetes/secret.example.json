{
  "apiVersion": "v1",
  "kind": "Secret",
  "metadata": {
    "name": "sdar-runtime-secrets",
    "namespace": "sdar-system"
  },
  "type": "Opaque",
  "stringData": {
    "DATABASE_URL": "postgresql://replace-user:replace-password@replace-postgres:5432/sdar_runtime",
    "JWT_HS256_SECRET": "replace-with-at-least-32-random-characters"
  }
}
