RUNTIME_ENV=development
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info
PROVIDER_ID=mock-provider
DATABASE_URL=postgresql://sdar:sdar@127.0.0.1:5432/sdar_runtime
ADAPTER_ENDPOINT=127.0.0.1:7001
ADAPTER_TLS_MODE=disabled
AUTH_MODE=development
MCP_LEGACY_ENDPOINT_ENABLED=false
BUSINESS_EVENTS_ENABLED=false
BUSINESS_EVENTS_REQUIRED_FOR_RUNTIME_READY=false
BUSINESS_EVENTS_RETENTION_MS=604800000
BUSINESS_EVENTS_POLL_INTERVAL_MS=500
BUSINESS_EVENTS_MAX_SUBSCRIPTIONS=256
BUSINESS_EVENTS_MAX_SUBSCRIPTIONS_PER_AUTH=32
BUSINESS_EVENTS_MAX_QUEUE_MESSAGES=64
BUSINESS_EVENTS_MAX_QUEUE_BYTES=1048576
BUSINESS_EVENTS_REPLAY_BATCH_SIZE=256
BUSINESS_EVENTS_MAX_STREAM_DURATION_MS=3600000
BUSINESS_EVENTS_MAX_EVENT_BYTES=65536
BUSINESS_EVENTS_MAX_PAYLOAD_DEPTH=16
BUSINESS_EVENTS_MAX_PAYLOAD_NODES=4096
BUSINESS_EVENTS_MAX_PAYLOAD_STRING_BYTES=16384
BUSINESS_EVENT_MAPPING_DEADLINE_MS=60000
BUSINESS_EVENT_MAX_FUTURE_SKEW_MS=300000
BUSINESS_EVENT_CLOCK_SKEW_SAFETY_MS=300000
# Notification defaults below are bounded; see docs/operations/configuration.md for limits.
TASK_NOTIFICATION_POLL_INTERVAL_MS=500
TASK_NOTIFICATION_MAX_SUBSCRIPTIONS=256
TASK_NOTIFICATION_MAX_SUBSCRIPTIONS_PER_AUTH=32
TASK_NOTIFICATION_MAX_TASK_BINDINGS=4096
TASK_NOTIFICATION_MAX_QUEUE_MESSAGES=64
TASK_NOTIFICATION_MAX_QUEUE_BYTES=1048576
TASK_NOTIFICATION_BATCH_SIZE=256
ALLOW_WEAK_LEASE_CONFIGURATION=false
OUTBOX_SINK=internal_noop

# Required only for OUTBOX_SINK=webhook:
# OUTBOX_WEBHOOK_URL=https://events.example/outbox

# Optional for ADAPTER_TLS_MODE=required:
# ADAPTER_TLS_CA_PATH=/run/secrets/adapter/ca.pem
# ADAPTER_TLS_CERT_PATH=/run/secrets/adapter/client.pem
# ADAPTER_TLS_KEY_PATH=/run/secrets/adapter/client-key.pem

# Required only for AUTH_MODE=jwt_hs256; issuer and audience are optional:
# JWT_HS256_SECRET=replace-with-at-least-32-characters
# JWT_ISSUER=https://issuer.example
# JWT_AUDIENCE=sdar-runtime
ADAPTER_RPC_TIMEOUT_MS=5000
HTTP_BODY_LIMIT_BYTES=1048576
ARGUMENT_MAX_BYTES=1048576
ARGUMENT_MAX_DEPTH=32
ARGUMENT_MAX_NODES=10000
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_KEYS=10000
DATABASE_POOL_MAX=10
IDEMPOTENCY_LEASE_MS=30000
IDEMPOTENCY_WAIT_TIMEOUT_MS=10000
IDEMPOTENCY_POLL_MS=20
COMMAND_CLAIM_LEASE_MS=30000
SCHEDULE_CLAIM_LEASE_MS=30000
RECOVERY_LEASE_MS=30000
LEASE_SAFETY_MARGIN_MS=500
DB_PUBLICATION_BUDGET_MS=1000
INTERNAL_ENDPOINTS_ENABLED=false
INTERNAL_ADMIN_TOKEN=
ADAPTER_HEALTH_POLL_MS=5000
ADAPTER_HEALTH_FAILURE_THRESHOLD=2
SCHEDULER_POLL_MS=1000
OUTBOX_CLEANER_POLL_MS=60000
RECOVERY_POLL_MS=5000
TTL_CLEANER_POLL_MS=60000
TTL_PURGE_GRACE_MS=86400000
OUTBOX_PUBLISHED_RETENTION_MS=86400000
TTL_CLEANER_BATCH_SIZE=128
